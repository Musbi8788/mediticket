# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mediticket"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-minimum-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Modem Pay (set MODEMPAY_ENV=live when ready for production)
MODEMPAY_ENV="sandbox"
MODEMPAY_API_KEY="your-modempay-api-key"
MODEMPAY_WEBHOOK_SECRET="your-modempay-webhook-secret"
